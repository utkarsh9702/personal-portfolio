NODE_ENV=development
PORT=5000

# Comma-separated allowed frontend origins.
# Use http://localhost:3000 for local dev servers.
# Use your GitHub Pages / static site URL in production.
# If testing from file:// in a browser, include null temporarily for local testing only.
FRONTEND_ORIGIN=http://localhost:3000,null

# Resend
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=Portfolio Contact <contact@your-verified-domain.com>
OWNER_EMAIL=whyutkarshh@gmail.com

# Abuse protection
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=5
MAX_JSON_BODY_SIZE=10kb
